generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VisitStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum SignatureStatus {
  PENDING
  SIGNED
}

enum ReceivableStatus {
  PENDING
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  BANK_TRANSFER
  OTHER
}

enum CentralStockMovementType {
  INITIAL_LOAD
  MANUAL_ENTRY
  MANUAL_ADJUSTMENT_IN
  MANUAL_ADJUSTMENT_OUT
  RESTOCK_TO_CLIENT
  DEFECTIVE_RETURN_LOG
}

enum ConsignedStockMovementType {
  INITIAL_LOAD
  RESTOCK_IN
  SALE_OUT
  DEFECTIVE_RETURN_OUT
  LOSS_OUT
}

enum StockReferenceType {
  VISIT
  MANUAL
  INITIAL_LOAD
  ADJUSTMENT
}

model User {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(160)
  email            String    @unique @db.VarChar(200)
  passwordHash     String    @db.VarChar(255)
  isActive         Boolean   @default(true)
  sessionTokenHash String?   @unique @db.VarChar(128)
  sessionExpiresAt DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Product {
  id                   String                  @id @default(uuid()) @db.Uuid
  sku                  String                  @unique @db.VarChar(120)
  name                 String                  @db.VarChar(200)
  category             String?                 @db.VarChar(120)
  brand                String?                 @db.VarChar(120)
  model                String?                 @db.VarChar(120)
  color                String?                 @db.VarChar(80)
  voltage              String?                 @db.VarChar(80)
  connectorType        String?                 @db.VarChar(80)
  basePrice            Decimal                 @default(0) @db.Decimal(12, 2)
  costPrice            Decimal?                @db.Decimal(12, 2)
  isActive             Boolean                 @default(true)
  clientProducts       ClientProduct[]
  centralStockBalance  CentralStockBalance?
  centralStockMovement CentralStockMovement[]
  consignedBalances    ConsignedStockBalance[]
  consignedMovements   ConsignedStockMovement[]
  visitItems           VisitItem[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([name])
  @@index([category])
}

model Client {
  id                 String                 @id @default(uuid()) @db.Uuid
  tradeName          String                 @db.VarChar(200)
  legalName          String?                @db.VarChar(200)
  documentNumber     String?                @db.VarChar(32)
  stateRegistration  String?                @db.VarChar(32)
  contactName        String?                @db.VarChar(160)
  phone              String?                @db.VarChar(32)
  addressLine        String?                @db.VarChar(200)
  addressCity        String?                @db.VarChar(120)
  addressState       String?                @db.VarChar(80)
  addressZipcode     String?                @db.VarChar(16)
  notes              String?
  visitCycleDays     Int?
  requiresInvoice    Boolean                @default(false)
  isActive           Boolean                @default(true)
  clientProducts     ClientProduct[]
  consignedBalances  ConsignedStockBalance[]
  consignedMovements ConsignedStockMovement[]
  visits             Visit[]
  receivables        Receivable[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([tradeName])
}

model ClientProduct {
  id               String     @id @default(uuid()) @db.Uuid
  clientId         String     @db.Uuid
  productId        String     @db.Uuid
  /// Preco atual da configuracao do cliente/produto. O historico real fica em VisitItem.unitPrice.
  currentUnitPrice Decimal    @db.Decimal(12, 2)
  idealQuantity    Int?
  displayOrder     Int?
  isActive         Boolean    @default(true)
  client           Client     @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product          Product    @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  visitItems       VisitItem[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([clientId, productId])
  @@index([clientId, isActive])
  @@index([productId, isActive])
}

model CentralStockBalance {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @unique @db.Uuid
  currentQuantity Int      @default(0)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CentralStockMovement {
  id            String                   @id @default(uuid()) @db.Uuid
  productId     String                   @db.Uuid
  movementType  CentralStockMovementType
  quantity      Int
  referenceType StockReferenceType
  referenceId   String?                  @db.Uuid
  /// DEFECTIVE_RETURN_LOG registra rastreabilidade sem retornar saldo disponivel ao estoque central.
  note          String?
  product       Product                  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt     DateTime                 @default(now())

  @@unique([referenceType, referenceId, productId, movementType], map: "uq_central_move_ref_prod_type")
  @@index([productId, createdAt])
  @@index([referenceType, referenceId])
}

model ConsignedStockBalance {
  id              String   @id @default(uuid()) @db.Uuid
  clientId        String   @db.Uuid
  productId       String   @db.Uuid
  currentQuantity Int      @default(0)
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clientId, productId])
  @@index([clientId])
  @@index([productId])
}

model ConsignedStockMovement {
  id            String                      @id @default(uuid()) @db.Uuid
  clientId      String                      @db.Uuid
  productId     String                      @db.Uuid
  movementType  ConsignedStockMovementType
  quantity      Int
  referenceType StockReferenceType
  referenceId   String?                     @db.Uuid
  note          String?
  client        Client                      @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product       Product                     @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt     DateTime                    @default(now())

  @@unique([referenceType, referenceId, clientId, productId, movementType], map: "uq_consigned_move_ref_cli_prod_type")
  @@index([clientId, createdAt])
  @@index([productId, createdAt])
  @@index([clientId, productId, createdAt])
  @@index([referenceType, referenceId])
}

model Visit {
  id                   String          @id @default(uuid()) @db.Uuid
  visitCode            String          @unique @db.VarChar(64)
  clientId             String          @db.Uuid
  status               VisitStatus     @default(DRAFT)
  visitedAt            DateTime        @default(now())
  notes                String?
  totalAmount          Decimal         @default(0) @db.Decimal(12, 2)
  /// Snapshot do valor recebido no fechamento da visita; apos COMPLETED, recebimentos seguem por Payment.
  receivedAmountOnVisit Decimal        @default(0) @db.Decimal(12, 2)
  dueDate              DateTime?       @db.Date
  signatureStatus      SignatureStatus @default(PENDING)
  signatureName        String?         @db.VarChar(160)
  signatureImageKey    String?         @db.VarChar(255)
  signedAt             DateTime?
  completedAt          DateTime?
  /// Visitas concluidas tornam-se operacionalmente imutaveis; isso e reforcado no backend, nao so no banco.
  client               Client          @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items                VisitItem[]
  receivable           Receivable?
  receiptDocument      ReceiptDocument?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([clientId, visitedAt])
  @@index([status, visitedAt])
}

model VisitItem {
  id                     String        @id @default(uuid()) @db.Uuid
  visitId                String        @db.Uuid
  clientProductId        String?       @db.Uuid
  productId              String        @db.Uuid
  productSnapshotName    String        @db.VarChar(200)
  productSnapshotSku     String        @db.VarChar(120)
  productSnapshotLabel   String        @db.VarChar(255)
  quantityPrevious       Int           @default(0)
  quantityGoodRemaining  Int           @default(0)
  quantityDefectiveReturn Int          @default(0)
  quantityLoss           Int           @default(0)
  quantitySold           Int           @default(0)
  /// Snapshot historico do preco praticado na visita. Mudancas em ClientProduct.currentUnitPrice nao alteram este valor.
  unitPrice              Decimal       @default(0) @db.Decimal(12, 2)
  /// Snapshot historico do custo do produto no momento da conclusao da visita.
  costPriceSnapshot      Decimal?      @db.Decimal(12, 2)
  subtotalAmount         Decimal       @default(0) @db.Decimal(12, 2)
  suggestedRestockQuantity Int         @default(0)
  restockedQuantity      Int           @default(0)
  resultingClientQuantity Int          @default(0)
  notes                  String?
  visit                  Visit         @relation(fields: [visitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clientProduct          ClientProduct? @relation(fields: [clientProductId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  product                Product       @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@unique([visitId, productId])
  @@index([visitId])
  @@index([productId])
}

model Receivable {
  id               String           @id @default(uuid()) @db.Uuid
  visitId          String           @unique @db.Uuid
  clientId         String           @db.Uuid
  /// Receivable e Payment sao a fonte da verdade do financeiro da visita.
  /// amountReceived e amountOutstanding sao snapshots agregados derivados de Payment.
  originalAmount   Decimal          @default(0) @db.Decimal(12, 2)
  amountReceived   Decimal          @default(0) @db.Decimal(12, 2)
  amountOutstanding Decimal         @default(0) @db.Decimal(12, 2)
  status           ReceivableStatus @default(PENDING)
  dueDate          DateTime?        @db.Date
  issuedAt         DateTime         @default(now())
  settledAt        DateTime?
  visit            Visit            @relation(fields: [visitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  client           Client           @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  payments         Payment[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([clientId, status, dueDate])
  @@index([dueDate])
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  receivableId  String        @db.Uuid
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  reference     String?       @db.VarChar(160)
  notes         String?
  paidAt        DateTime      @default(now())
  receivable    Receivable    @relation(fields: [receivableId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt     DateTime      @default(now())

  @@index([receivableId, paidAt])
}

model ReceiptDocument {
  id         String   @id @default(uuid()) @db.Uuid
  visitId    String   @unique @db.Uuid
  storageKey String   @db.VarChar(255)
  fileName   String   @db.VarChar(200)
  mimeType   String   @default("application/pdf") @db.VarChar(120)
  checksum   String?  @db.VarChar(128)
  generatedAt DateTime @default(now())
  visit      Visit    @relation(fields: [visitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
