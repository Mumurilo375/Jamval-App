NODE_ENV="development"
HOST="0.0.0.0"
PORT="3333"
LOG_LEVEL="info"
AUTH_SESSION_TTL_HOURS="168"
AUTH_COOKIE_NAME="jamval_session"
# Em producao, informe a URL do frontend (ou lista separada por virgula).
# Exemplo: CORS_ORIGIN="https://seu-frontend.vercel.app"
# CORS_ORIGIN="https://seu-frontend.vercel.app,https://www.seudominio.com"
CORS_ORIGIN=""

# Opcao 1: usar DATABASE_URL diretamente.
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jamval?schema=public"
#
# Opcional em producao: usar uma conexao direta para migrations do Prisma.
# Em provedores com pooler (ex.: Supabase), prefira a URL direta aqui e deixe DATABASE_URL para a aplicacao.
# DIRECT_URL="postgresql://postgres:postgres@db.seu-projeto.supabase.co:5432/postgres?sslmode=require"

# Opcao 2: usar banco local com variaveis separadas.
DB_SYNC="true"
DB_NAME="jamval"
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_HOST="localhost"
DB_PORT="5432"
DB_LOGGING="false"

# Opcional: sobrescreve onde recibos e assinaturas sao salvos.
# STORAGE_ROOT="../storage"
